# Copy this file to .env and fill in your values.

# Database connection string.
# SQLite (default, no setup required):
DATABASE_URL=sqlite:///./andel_newsletter.db
# PostgreSQL (swap in when you need it):
# DATABASE_URL=postgresql://user:password@localhost:5432/andel

# Comma-separated list of allowed frontend origins for CORS.
# Use * only in development.
ALLOWED_ORIGINS=http://localhost:8000,https://andel.ca,https://www.andel.ca

# Auth — JWT signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set to "true" in production (requires HTTPS). Leave "false" for localhost dev.
COOKIE_SECURE=false

# Required to create resident accounts via POST /api/auth/register.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
# Leave blank to disable registration entirely.
REGISTRATION_SECRET=

# Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (leave blank to disable)
# Use "common" to allow both personal and work/school accounts.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
